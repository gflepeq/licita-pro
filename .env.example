# Copia este archivo como .env.local (desarrollo) o define las variables en el
# panel de tu plataforma de deploy (Railway/Render/Fly).

# Secreto para firmar las sesiones JWT. Genera uno con:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
AUTH_SECRET=

# Ticket de la API de Mercado Público (ChileCompra).
# Solicítalo en https://www.chilecompra.cl/api/
MERCADO_PUBLICO_TICKET=

# (Opcional) Carpeta donde se guarda la base SQLite. En producción apúntala al
# volumen persistente montado, p. ej. /data
# DATA_DIR=/data
