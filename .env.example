# Copia este archivo como .env.local (desarrollo) o define las variables en el
# panel de tu plataforma de deploy.

# Secreto para firmar las sesiones JWT. Genera uno con:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
AUTH_SECRET=

# Ticket de la API de Mercado Público (ChileCompra).
# Solicítalo en https://www.chilecompra.cl/api/
MERCADO_PUBLICO_TICKET=

# (Opcional, pendiente) API de Compra Ágil / recomendaciones (beta) — trae
# garantías, región, estado, montos. Endpoint exacto en la guía PDF que entrega
# ChileCompra al solicitar el ticket con Clave Única.
COMPRA_AGIL_API_BASE=
COMPRA_AGIL_API_TICKET=

# --- Base de datos: Supabase (Postgres) ---
# Crea el proyecto en https://supabase.com y copia la connection string del
# POOLER (Project Settings → Database → Connection pooling → modo "Transaction",
# puerto 6543). Las tablas se crean solas en el primer arranque.
#   DATABASE_URL=postgresql://postgres.<ref>:<password>@aws-...pooler.supabase.com:6543/postgres
DATABASE_URL=

# --- Pagos: Flow.cl ---
# Solicita tus credenciales en https://www.flow.cl (Mi cuenta → API).
# Sandbox para pruebas: https://sandbox.flow.cl/api  ·  Producción: https://www.flow.cl/api
FLOW_API_KEY=
FLOW_SECRET_KEY=
FLOW_API_URL=https://sandbox.flow.cl/api
# URL pública del sitio (para los callbacks de Flow). Ej: https://liciapp.cl
APP_URL=

# Emails con acceso al panel Super Admin (/admin), separados por coma.
# Si se deja vacío (modo demo), la cuenta demo@licitapro.cl es admin.
# El primer usuario registrado siempre queda como admin.
ADMIN_EMAILS=
